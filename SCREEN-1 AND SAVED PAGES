import 'dart:io';
import 'package:flutter/material.dart';
import '../storage/page_storage.dart';
import 'offline_viewer.dart';

class SavedPagesScreen extends StatefulWidget {
  const SavedPagesScreen({super.key});

  @override
  State<SavedPagesScreen> createState() => _SavedPagesScreenState();
}

class _SavedPagesScreenState extends State<SavedPagesScreen> {
  List<FileSystemEntity> pages = [];

  @override
  void initState() {
    super.initState();
    loadPages();
  }

  void loadPages() async {
    pages = await PageStorage.getSavedPages();
    setState(() {});
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("Saved Pages")),
      body: pages.isEmpty
          ? const Center(child: Text("No saved pages yet"))
          : ListView.builder(
              itemCount: pages.length,
              itemBuilder: (context, index) {
                final file = pages[index];

                return ListTile(
                  leading: const Icon(Icons.public),
                  title: Text(file.path.split('/').last),
                  onTap: () {
                    Navigator.push(
                      context,
                      MaterialPageRoute(
                        builder: (_) =>
                            OfflineViewer(path: file.path),
                      ),
                    );
                  },
                );
              },
            ),
    );
  }
}
