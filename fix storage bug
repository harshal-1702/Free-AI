import 'dart:io';
import 'package:path_provider/path_provider.dart';

class PageStorage {
  static Future<Directory> _getDir() async {
    final dir = await getApplicationDocumentsDirectory();
    final folder = Directory('${dir.path}/pages');

    if (!await folder.exists()) {
      await folder.create(recursive: true);
    }

    return folder;
  }

  static Future<String> savePage(String url, String html) async {
    final folder = await _getDir();

    final fileName = DateTime.now().millisecondsSinceEpoch.toString();
    final file = File('${folder.path}/$fileName.html');

    await file.writeAsString(html);

    return file.path;
  }

  static Future<List<FileSystemEntity>> getSavedPages() async {
    final folder = await _getDir();
    return folder.list().toList();
  }

  static Future<String> readPage(String path) async {
    return File(path).readAsString();
  }
}
