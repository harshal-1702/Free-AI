import 'dart:io';
import 'package:path_provider/path_provider.dart';

class PageStorage {

  // Save HTML page
  static Future<String> savePage(String url, String html) async {
    final dir = await getApplicationDocumentsDirectory();

    final fileName = url.replaceAll(RegExp(r'[^a-zA-Z0-9]'), '_');
    final file = File('${dir.path}/$fileName.html');

    await file.writeAsString(html);

    return file.path;
  }

  // Get all saved pages
  static Future<List<FileSystemEntity>> getSavedPages() async {
    final dir = await getApplicationDocumentsDirectory();
    final folder = Directory(dir.path);

    return folder.list().where((file) => file.path.endsWith(".html")).toList();
  }

  // Read saved page
  static Future<String> readPage(String path) async {
    final file = File(path);
    return file.readAsString();
  }
}

